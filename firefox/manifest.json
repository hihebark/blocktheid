{
  "manifest_version": 2,
  "name": "Blocktheid",
  "version": "1.0.0",
  "description": "Blocks websites hosted on Vercel to boycott Israel's war on Gaza",
  "permissions": [
    "storage",
    "activeTab",
    "webNavigation",
    "tabs"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Blocktheid"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}